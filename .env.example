# Environment variables
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=password
DB_NAME=rplacefr

TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret

# JWT - Générer une clé secrète forte pour la production
JWT_SECRET_KEY=change-this-to-a-strong-secret-key-in-production
JWT_EXPIRE_MINUTES=1440

# Cookie - True en production (HTTPS requis)
COOKIE_SECURE=false

# CORS - Ajouter les origines autorisées pour les requêtes cross-origin
CORS_ORIGINS=http://localhost:5173